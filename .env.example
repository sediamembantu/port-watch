# Optional: Secure the cron endpoint (set in Vercel dashboard)
CRON_SECRET=your-secret-here

# Optional: AISStream.io API key for real-time vessel tracking
# Free registration at https://aisstream.io/
AISSTREAM_API_KEY=your-aisstream-key-here

# Required: Vercel KV (auto-injected when you link a KV store in Vercel dashboard)
KV_REST_API_URL=your-kv-url
KV_REST_API_TOKEN=your-kv-token
